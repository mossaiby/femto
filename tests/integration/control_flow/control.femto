test_if :: (int32 x) -> int32
{
    if (x > 0) then
    {
        return 1;
    }
    else
    {
        return 0;
    }
}

test_while :: () -> int32
{
    int32 i = 0;
    while (i < 10)
    {
        i = i + 1;
    }
    return i;
}

test_do_while :: () -> int32
{
    int32 i = 0;
    do
    {
        i = i + 1;
    } while (i < 5);
    return i;
}

test_switch :: (int32 x) -> int32
{
    switch (x)
    {
        case 1 { return 10; }
        case 2 { return 20; }
        default { return 0; }
    }
}

test_break :: () -> int32
{
    int32 i = 0;
    while (true)
    {
        if (i == 5) then { break; }
        i = i + 1;
    }
    return i;
}
