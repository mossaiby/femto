safe_divide :: (int32 a, int32 b) -> !int32
{
    if (b == 0) then
    {
        return failure(1);
    }
    else
    {
        return success(a / b);
    }
}

test_error_handling :: () -> int32
{
    safe_divide(10, 0)
        ?? (int32 result) { return result; }
        :  (int32 code) { return code; };
    return 0;
}
