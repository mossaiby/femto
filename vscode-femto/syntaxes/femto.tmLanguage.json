{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "femto",
  "scopeName": "source.femto",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#decorators" },
    { "include": "#directives" },
    { "include": "#operators" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.femto",
          "match": "//.*$"
        },
        {
          "name": "comment.block.femto",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.femto",
          "match": "\\b(if|then|else|while|do|for|foreach|in|switch|case|default|return|break|continue|match)\\b"
        },
        {
          "name": "keyword.declaration.femto",
          "match": "\\b(function|struct|enum|union|namespace|import|extern|export|const|var)\\b"
        },
        {
          "name": "keyword.other.femto",
          "match": "\\b(success|failure|null|void|true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.femto",
          "match": "\\b(int8|int16|int32|int64|int128|int256|int512|uint8|uint16|uint32|uint64|uint128|uint256|uint512|float16|float32|float64|float128|bool8|bool16|bool32|bool64|bool128|bool256|bool512|char8|char16|char32|string8|string16|string32)\\b"
        },
        {
          "match": "(\\b[a-zA-Z_][a-zA-Z0-9_]*\\b)\\s*(<)",
          "captures": {
            "1": { "name": "entity.name.type.femto" },
            "2": { "name": "punctuation.definition.type-parameters.begin.femto" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Z0-9_]*)\\b",
          "name": "variable.other.constant.femto"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "keyword.operator.at.femto",
          "match": "@(target|arch|endian|file|line|sizeof|alignof|typeof|bitcast)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.femto",
          "match": "#(export|if|else)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.femto",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.femto",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.femto",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.logical.femto",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.femto",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.special.femto",
          "match": "(\\?\\?|\\+\\+|--)"
        },
        {
          "name": "keyword.operator.namespace.femto",
          "match": "(::)"
        },
        {
          "name": "keyword.operator.arrow.femto",
          "match": "(->)"
        },
        {
          "name": "keyword.operator.address.femto",
          "match": "(&)"
        },
        {
          "name": "keyword.operator.dereference.femto",
          "match": "(\\*)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.femto",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.femto",
              "match": "\\\\(n|t|r|0|\\\\|\"|u\\{[0-9a-fA-F]+\\})"
            }
          ]
        },
        {
          "name": "string.quoted.other.raw.femto",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.femto",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.femto",
              "match": "\\\\(n|t|r|0|\\\\|'|u\\{[0-9a-fA-F]+\\})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.femto",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.femto",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.femto",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.float.femto",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.femto",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.femto" },
            "2": { "name": "punctuation.definition.arguments.begin.femto" }
          }
        },
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(::<)",
          "captures": {
            "1": { "name": "entity.name.function.femto" },
            "2": { "name": "punctuation.definition.type-parameters.begin.femto" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b[a-z][a-z0-9_]*\\b",
          "name": "variable.other.femto"
        }
      ]
    }
  }
}